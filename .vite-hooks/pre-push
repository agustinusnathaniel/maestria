# Fail fast if Python 3 is missing (used by check-python quality gate)
if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 is required for 'vp run check-python'."
  echo "  Install Python 3.11+ from https://python.org or your package manager."
  exit 1
fi

vp run check && vp run check-python
