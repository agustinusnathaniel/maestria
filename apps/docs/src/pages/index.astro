---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { LinkButton } from '@astrojs/starlight/components';
import { agents, type Agent } from '../data/agents.js';
---

<StarlightPage
  frontmatter={{
    title: 'Maestria',
    description: 'Portable AI engineering praxis plugins for OpenCode and beyond. Installable, self-wiring plugins that encode effective workflows.',
    template: 'splash',
    hero: { tagline: '' },
    editUrl: false,
    lastUpdated: false,
  }}
>
  <section class="hero">
    <h1>Maestria</h1>
    <p class="tagline">Portable AI engineering praxis, encoded as plugins.</p>
    <div class="hero-cta">
      <LinkButton href="/cli/getting-started/" class="sl-link-button">Get Started</LinkButton>
      <LinkButton href="/core/agents/" class="sl-link-button outline">Browse Agents</LinkButton>
    </div>
  </section>

  <section class="features">
    <h2>Why Maestria?</h2>
    <div class="features-grid">
      <div class="feature-card">
        <h3>🔌 Pipeline Composition</h3>
        <p>Chain specialist agents into adaptive workflows. Each agent handles one cognitive role — thinker, worker, verifier — and the orchestrator sequences them dynamically based on task needs.</p>
      </div>
      <div class="feature-card">
        <h3>🛡️ Maker/Checker Split</h3>
        <p>The agent that writes code never reviews it. Every implementation passes through a separate reviewer, catching issues that same-agent QA would miss.</p>
      </div>
      <div class="feature-card">
        <h3>🌐 Platform Independence</h3>
        <p>Core logic lives in platform-agnostic packages. Plugin adapters for OpenCode, Kimi Code, and Pi keep the same agent behavior across different AI platforms.</p>
      </div>
    </div>
  </section>

  <section class="agent-showcase">
    <h2>The Pipeline</h2>
    <p>Eight specialist agents, each handling one cognitive role. The orchestrator sequences them dynamically.</p>

    <div class="agent-tabs" role="tablist">
      {agents.map((agent: Agent, index: number) => (
        <button
          class="agent-tab"
          role="tab"
          aria-selected={index === 0 ? 'true' : 'false'}
          aria-controls={`panel-${agent.id}`}
          id={`tab-${agent.id}`}
        >
          <span class="agent-tab-icon">{agent.icon}</span>
          <span class="agent-tab-name">{agent.name}</span>
        </button>
      ))}
    </div>

    {agents.map((agent: Agent, index: number) => (
      <div
        class="agent-panel"
        role="tabpanel"
        id={`panel-${agent.id}`}
        aria-labelledby={`tab-${agent.id}`}
        hidden={index !== 0}
      >
        <h3>{agent.name}</h3>
        <p class="agent-role">{agent.role}</p>
        <p>{agent.description}</p>
      </div>
    ))}
  </section>

  <section class="platforms">
    <h2>Built for Your Stack</h2>
    <p>Maestria ships as plugins for the AI coding platforms you already use.</p>

    <div class="product-grid">
      <a href="/opencode/" class="product-card">
        <h2>
          <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="4 17 10 11 4 5" />
            <line x1="12" y1="19" x2="20" y2="19" />
          </svg>
          @maestria/opencode
        </h2>
        <p>8 specialized agents with global rules injected into every session.</p>
        <span class="product-card-link">Learn more →</span>
      </a>

      <a href="/kimi-code/" class="product-card">
        <h2>
          <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="5" r="2" />
            <circle cx="5" cy="19" r="2" />
            <circle cx="19" cy="19" r="2" />
            <line x1="12" y1="7" x2="5" y2="17" />
            <line x1="12" y1="7" x2="19" y2="17" />
            <line x1="7" y1="19" x2="17" y2="19" />
          </svg>
          @maestria/kimi-code
        </h2>
        <p>8 specialized skills with swarm-aware orchestration and no build step.</p>
        <span class="product-card-link">Learn more →</span>
      </a>

      <a href="/pi/" class="product-card">
        <h2>
          <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polygon points="5 3 19 12 5 21 5 3" />
          </svg>
          @maestria/pi
        </h2>
        <p>7 specialist subagents with spec-driven orchestration and deep session-tree integration.</p>
        <span class="product-card-link">Learn more →</span>
      </a>
    </div>
  </section>
</StarlightPage>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.agent-tab');
    const panels = document.querySelectorAll('.agent-panel');

    function activateTab(tab: Element) {
      tabs.forEach(t => t.setAttribute('aria-selected', 'false'));
      panels.forEach(p => p.setAttribute('hidden', ''));

      tab.setAttribute('aria-selected', 'true');
      const panelId = tab.getAttribute('aria-controls');
      const panel = document.getElementById(panelId!);
      if (panel) panel.removeAttribute('hidden');

      // Track agent tab click
      if (typeof window !== 'undefined' && window.umami) {
        const agentName = tab.querySelector('.agent-tab-name')?.textContent?.trim() || tab.textContent?.trim();
        window.umami.track('agent_tab_click', { agent: agentName });
      }
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => activateTab(tab));
    });

    document.addEventListener('keydown', (e) => {
      const target = e.target as HTMLElement;
      const tab = target.closest('.agent-tab');
      if (!tab) return;

      const tabsArray = Array.from(tabs);
      const index = tabsArray.indexOf(tab);

      let nextIndex: number | null = null;
      if (e.key === 'ArrowRight') nextIndex = (index + 1) % tabsArray.length;
      if (e.key === 'ArrowLeft') nextIndex = (index - 1 + tabsArray.length) % tabsArray.length;
      if (e.key === 'Home') nextIndex = 0;
      if (e.key === 'End') nextIndex = tabsArray.length - 1;

      if (nextIndex !== null) {
        e.preventDefault();
        activateTab(tabsArray[nextIndex]);
        (tabsArray[nextIndex] as HTMLElement).focus();
      }
    });
  });
</script>
