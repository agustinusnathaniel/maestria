{
  "name": "maestria",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp run @maestria/docs#dev",
    "prepare": "vp config",
    "preview": "vp run @maestria/docs#preview",
    "sync:docs": "vp run --filter @maestria/docs sync",
    "prebuild": "vp run check-sync",
    "build": "vp run -r build",
    "prebuild:ci": "vp run check-sync",
    "build:ci": "vp run --filter './packages/*' --filter ./apps/maestria-cli build",
    "test": "vp run -r test",
    "changeset": "changeset",
    "version-packages": "changeset version && python scripts/sync-hermes-version.py",
    "release": "changeset publish",
    "check": "vp check && vp run build && vp run test",
    "check:ci": "vp check && pnpm build:ci && vp run test",
    "clean": "vp cache clean",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "typecheck": "vp check --no-fmt --no-lint"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@types/node": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.16.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=24.16.x"
  },
  "packageManager": "pnpm@11.8.0"
}
